# Stage 1: Build
FROM node:22-alpine AS build
WORKDIR /app
ARG BASE_HREF=/
ARG API_BASE_URL=https://localhost:8443
ARG MSAL_CLIENT_ID=<ui-client-id>
ARG MSAL_AUTHORITY=https://login.microsoftonline.com/<tenant-guid>
ARG MSAL_REDIRECT_URI=http://localhost:4200
ARG MSAL_POST_LOGOUT_REDIRECT_URI=http://localhost:4200
ARG MSAL_SCOPES=api://<api-client-id>/access_as_user
ARG NPM_TOKEN=
COPY src/test-ui/package.json src/test-ui/package-lock.json* ./
RUN if [ -n "${NPM_TOKEN}" ]; then \
            echo "registry=https://artifactory.wolterskluwer.io/artifactory/api/npm/group-npm/" > .npmrc && \
            echo "//artifactory.wolterskluwer.io/artifactory/api/npm/group-npm/:_authToken=${NPM_TOKEN}" >> .npmrc; \
        fi && \
        npm ci && \
        rm -f .npmrc
COPY src/test-ui/ ./
RUN npx ng build --configuration production --base-href ${BASE_HREF} && \
    find /app/dist/test-ui/browser -type f -name "*.js" -exec sed -i "s|https://localhost:8443|${API_BASE_URL}|g" {} + && \
    find /app/dist/test-ui/browser -type f -name "*.js" -exec sed -i "s|<ui-client-id>|${MSAL_CLIENT_ID}|g" {} + && \
    find /app/dist/test-ui/browser -type f -name "*.js" -exec sed -i "s|https://login.microsoftonline.com/<tenant-guid>|${MSAL_AUTHORITY}|g" {} + && \
    find /app/dist/test-ui/browser -type f -name "*.js" -exec sed -i "s|http://localhost:4200|${MSAL_REDIRECT_URI}|g" {} + && \
    find /app/dist/test-ui/browser -type f -name "*.js" -exec sed -i "s|api://<api-client-id>/access_as_user|${MSAL_SCOPES}|g" {} +

# Generate self-signed TLS certificate
RUN apk add --no-cache openssl && \
    mkdir -p /https && \
    openssl req -x509 -nodes -days 365 -newkey rsa:2048 \
      -keyout /https/tls.key \
      -out /https/tls.crt \
      -subj "/CN=bizscraper-ui" \
      -addext "subjectAltName=DNS:bizscraper-ui,DNS:localhost"

# Stage 2: Runtime
FROM nginx:alpine AS runtime
# Remove default nginx config
RUN rm /etc/nginx/conf.d/default.conf
# Copy custom nginx config
COPY src/test-ui/nginx.conf /etc/nginx/conf.d/default.conf
# Copy Angular build output
COPY --from=build /app/dist/test-ui/browser /usr/share/nginx/html
# Copy TLS certificate from build stage
COPY --from=build /https /etc/nginx/certs
RUN chown -R nginx:nginx /var/cache/nginx && \
    chown -R nginx:nginx /var/log/nginx && \
    chown -R nginx:nginx /etc/nginx/certs && \
    touch /var/run/nginx.pid && \
    chown nginx:nginx /var/run/nginx.pid
EXPOSE 8080 8443
USER nginx
CMD ["nginx", "-g", "daemon off;"]
